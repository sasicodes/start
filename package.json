{
  "name": "start",
  "private": true,
  "license": "MIT",
  "description": "your coding assistant",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "homepage": "https://start.intelligence.one",
  "scripts": {
    "audit": "pnpm run audit:deps && pnpm run audit:signatures",
    "audit:deps": "pnpm audit && pnpm --dir packages/desktop audit",
    "audit:signatures": "node scripts/audit-signatures.js",
    "build": "pnpm run build:desktop && pnpm run build:web",
    "build:desktop": "pnpm --filter @start/desktop build",
    "build:web": "pnpm --filter @start/web build",
    "check": "pnpm run check:pins && pnpm run lint && pnpm run format && pnpm run typecheck",
    "check:fix": "pnpm run check:pins && biome check . --write && pnpm run typecheck",
    "check:pins": "node scripts/check-dependency-pins.js",
    "dev": "pnpm --filter @start/desktop dev",
    "dist": "pnpm --filter @start/desktop dist",
    "format": "biome ci --linter-enabled=false --assist-enabled=false .",
    "format:fix": "biome format . --write",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "biome lint . --error-on-warnings",
    "package": "pnpm --filter @start/desktop package",
    "relay": "pnpm --filter @start/relay build && pnpm --filter @start/relay start",
    "test": "pnpm --filter @start/desktop test",
    "typecheck": "pnpm --filter @start/desktop typecheck && pnpm --filter @start/relay typecheck && pnpm --filter @start/web typecheck",
    "web": "pnpm --filter @start/web dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2"
  }
}
