{
  "name": "@start/relay",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "description": "relay for start remote access",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --target=node24 --external:bufferutil --external:utf-8-validate --banner:js=\"import{createRequire as __cr}from'node:module';const require=__cr(import.meta.url);\" --outfile=dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@hono/node-server": "1.19.6",
    "hono": "4.10.7",
    "valibot": "1.4.0",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "@types/ws": "8.18.1",
    "esbuild": "0.27.7",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
