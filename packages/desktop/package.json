{
  "name": "@start/desktop",
  "private": true,
  "productName": "Start",
  "version": "0.1.0-alpha.33",
  "license": "MIT",
  "description": "your coding assistant",
  "type": "module",
  "main": "out/main/index.cjs",
  "homepage": "https://start.intelligence.one",
  "scripts": {
    "dev": "electron-vite dev",
    "check": "pnpm run typecheck",
    "clean": "node scripts/clean.js",
    "build": "electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.test.json --pretty false",
    "build:prod": "pnpm run typecheck && electron-vite build",
    "dist": "pnpm run clean && pnpm run build:prod && electron-builder",
    "dist:mac": "pnpm run clean && pnpm run build:prod && electron-builder --mac",
    "package": "pnpm run clean && pnpm run build:prod && electron-builder --dir",
    "package:mac": "pnpm run clean && pnpm run build:prod && electron-builder --mac --dir"
  },
  "keywords": [
    "vite",
    "preact",
    "electron",
    "coding-agent"
  ],
  "author": "sasicodes",
  "dependencies": {
    "@ff-labs/fff-node": "0.9.6",
    "@vscode/ripgrep": "1.18.0",
    "ffi-rs": "1.3.2"
  },
  "devDependencies": {
    "@base-ui/react": "1.6.0",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@electron/notarize": "3.1.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@preact/preset-vite": "2.10.5",
    "@preact/signals": "2.9.3",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/hotkeys": "0.8.0",
    "@types/node": "26.1.0",
    "@types/ws": "8.18.1",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "electron-updater": "6.8.9",
    "electron-vite": "6.0.0-beta.1",
    "katex": "0.17.0",
    "motion": "12.42.2",
    "posthog-node": "5.39.4",
    "preact": "10.29.5",
    "streamdown": "2.5.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "valibot": "1.4.2",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "ws": "8.21.0"
  },
  "build": {
    "appId": "one.intelligence.start",
    "productName": "Start",
    "copyright": "Copyright © 2026 Intelligence One",
    "asar": true,
    "asarUnpack": [
      "node_modules/@yuuang/ffi-rs-*/**/*.node",
      "node_modules/@vscode/ripgrep-*/bin/**",
      "node_modules/@ff-labs/fff-bin-*/**/*.{so,dll,dylib}"
    ],
    "compression": "maximum",
    "detectUpdateChannel": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "build/icons/icon.icns",
      "build/icons/icon.ico",
      "build/icons/icon.png",
      "build/icons/tray-icon.png",
      "package.json",
      "!out/renderer/icon-dev.png",
      "!**/*.map"
    ],
    "extraMetadata": {
      "homepage": "https://start.intelligence.one"
    },
    "afterPack": "scripts/sanitize-mac-info.js",
    "afterSign": "scripts/notarize.js",
    "electronFuses": {
      "runAsNode": false,
      "onlyLoadAppFromAsar": true,
      "enableNodeCliInspectArguments": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableEmbeddedAsarIntegrityValidation": true
    },
    "dmg": {
      "format": "ULFO",
      "iconSize": 96,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "background": "build/installer/background.png",
      "contents": [
        {
          "x": 180,
          "y": 195,
          "type": "file"
        },
        {
          "x": 480,
          "y": 195,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 660,
        "height": 400
      }
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.developer-tools",
      "entitlements": "build/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "minimumSystemVersion": "13.0",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSDesktopFolderUsageDescription": "Start needs access to project files you choose so your coding assistant can read and edit them.",
        "NSDocumentsFolderUsageDescription": "Start needs access to project files you choose so your coding assistant can read and edit them.",
        "NSDownloadsFolderUsageDescription": "Start needs access to project files you choose so your coding assistant can read and edit them.",
        "NSNetworkVolumesUsageDescription": "Start needs access to project folders you choose on network volumes.",
        "NSPrefersDisplaySafeAreaCompatibilityMode": false,
        "NSRemovableVolumesUsageDescription": "Start needs access to project folders you choose on removable drives.",
        "NSRequiresAquaSystemAppearance": false
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "target": "AppImage",
      "category": "Development"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "publish": [
      {
        "provider": "github",
        "owner": "sasicodes",
        "repo": "start"
      }
    ]
  }
}
